-- ─── Main Farm Loop ──────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoBones and _G.SelectedBoneNPC then
            local npc = BoneNPCs[_G.SelectedBoneNPC]
            if not npc then task.wait(1); continue end

            -- Check sea
            local seaOK = (npc.Sea == "First"  and First_Sea)
                       or (npc.Sea == "Second" and Second_Sea)
                       or (npc.Sea == "Third"  and Third_Sea)
            if not seaOK then
                SetStatus("⚠ Wrong sea for " .. _G.SelectedBoneNPC)
                task.wait(2)
                continue
            end

            -- Check level
            local lvData = player:FindFirstChild("Data")
            local playerLv = lvData and lvData:FindFirstChild("Level")
                             and lvData.Level.Value or 0
            if playerLv < npc.MinLevel then
                SetStatus("⚠ Level too low (need " .. npc.MinLevel .. ")")
                task.wait(2)
                continue
            end

            -- 1) Take quest if not already active
            if not HasQuest() then
                SetStatus("📋 Taking quest...")
                Tween(npc.QuestCFrame)
                task.wait(0.6)
                TakeQuest(npc.QuestName, npc.QuestLevel)
                task.wait(0.5)
            end

            -- 2) Find nearest monster
            SetStatus("🔍 Finding " .. npc.MonsterName .. "...")
            local enemy = FindNearestEnemy(npc.MonsterName)

            if enemy then
                SetStatus("⚔ Killing " .. npc.MonsterName .. "...")
                KillEnemy(enemy)
                task.wait(0.3)
            else
                -- Warp to known spawn
                Warp(npc.MonsterCFrame)
                task.wait(0.8)
            end
        end
    end
end)

