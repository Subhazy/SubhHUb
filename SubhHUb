local function GetMoonInfo()
    local ok, sky = pcall(function()
        return game:GetService("Lighting").Sky
    end)
    if not ok or not sky then
        return { name = "☀️ Daytime / No Moon", pct = "0%" }
    end
    local id = sky.MoonTextureId
    return MoonTextures[id] or { name = "☀️ Daytime / No Moon", pct = "0%" }
end

local function IsFullMoon()
    local info = GetMoonInfo()
    return info.pct == "100%"
end

