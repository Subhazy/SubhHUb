-- ─── Helpers ─────────────────────────────────────────────────────────────────

-- Smooth tween to CFrame
local function Tween(cf, duration)
    duration = duration or 0.15
    local char = player.Character
    if not char then return end
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    if not hrp  then return end
    local info = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local goal = { CFrame = cf }
    TweenService:Create(hrp, info, goal):Play()
    task.wait(duration + 0.05)
end

-- Instant warp
local function Warp(cf)
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = cf end
end

-- Is quest active?
local function HasQuest()
    local data = player:FindFirstChild("Data")
    if not data then return false end
    local qData = data:FindFirstChild("QuestData")
    if qData then
        return qData.Value ~= "" and qData.Value ~= "none"
    end
    -- fallback: try QuestLevel attribute
    local ql = data:FindFirstChild("QuestLevel")
    return ql and ql.Value > 0
end

-- Take quest via server remote
local function TakeQuest(questName, questLv)
    pcall(function()
        CommF_:InvokeServer("TakeQuest", questName, questLv)
    end)
    task.wait(0.5)
end

-- Find nearest enemy by name
local function FindNearestEnemy(name)
    local char  = player.Character
    if not char then return nil end
    local hrp   = char:FindFirstChild("HumanoidRootPart")
    if not hrp  then return nil end

    local nearest, nearDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == name and obj:IsA("Model") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            local root = obj:FindFirstChild("HumanoidRootPart")
                        or obj:FindFirstChild("Torso")
                        or obj:FindFirstChild("UpperTorso")
            if hum and hum.Health > 0 and root then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < nearDist then
                    nearest  = obj
                    nearDist = dist
                end
            end
        end
    end
    return nearest
end

-- Kill a model by continuously teleporting onto it and using equipped tool
local function KillEnemy(enemy)
    local data = BoneNPCs[_G.SelectedBoneNPC]
    if not data then return end

    -- Teleport on top of enemy
    local eRoot = enemy:FindFirstChild("HumanoidRootPart")
                or enemy:FindFirstChild("Torso")
                or enemy:FindFirstChild("UpperTorso")
    if not eRoot then return end

    local hum = enemy:FindFirstChildOfClass("Humanoid")
    local timeout = tick() + 30  -- give up after 30 s

    while hum and hum.Health > 0 and tick() < timeout and _G.AutoBones do
        -- Stick on enemy
        Warp(eRoot.CFrame * CFrame.new(0, 3, 0))
        -- Use equipped tool / fist attacks via remote
        pcall(function()
            local tool = player.Character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Handle") then
                -- Simulate tool activation
                local activate = tool:FindFirstChild("RemoteEvent")
                                or tool:FindFirstChild("RemoteFunction")
                if activate then
                    pcall(function() activate:FireServer() end)
                end
            end
        end)
        -- Generic damage remote (works for most melee/fist attacks in BF)
        pcall(function()
            CommF_:InvokeServer("Damage", enemy, math.random(500,2000))
        end)
        task.wait(0.08)
    end
end

