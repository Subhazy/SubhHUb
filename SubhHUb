local EliteNames = { "Diablo", "Deandre", "Urban" }

local function IsElitePresent()
    local rs = game:GetService("ReplicatedStorage")
    local enemies = workspace:FindFirstChild("Enemies")
    for _, name in ipairs(EliteNames) do
        if rs:FindFirstChild(name) then return true, name end
        if enemies and enemies:FindFirstChild(name) then return true, name end
    end
    return false, nil
end

